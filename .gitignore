# --- Python / RAPIDS ---
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/

# --- Data & models (large; keep out of git) ---
# Top-level data/ dumps only — NOT the waspada/data/ source package.
/data/
*.csv
*.parquet
*.feather
*.zip
models/
*.pkl
*.joblib

# --- Secrets / GCP credentials (NEVER commit) ---
.env
.env.*
!.env.example
service-account*.json
gcp-*.json
credentials*.json
*-key.json

# --- Node / frontend (Kirana's dashboard) ---
node_modules/
dist/
.vite/

# --- Benchmark scratch (WA-007) ---
# Per-run artifacts are large and machine-specific; only bench/LAST_RUN.json
# (the committed snapshot for the README) is tracked.
bench/results/

# --- OS / editor ---
.DS_Store
Thumbs.db

*.pptx
.venv-qa/
*.pdf

# --- Build artifacts ---
# Scratch dashboard build output; never committed (swept into a stash once).
.dbuild/

# --- OpenTofu / Terraform (WA-027) ---
# State files may contain sensitive values; never commit.
*.tfstate
*.tfstate.*
# tfvars carry credentials (secrets.tfvars). Only *.tfvars.example is tracked.
*.tfvars
!secrets.tfvars.example
.terraform/
.terraform.lock.hcl
