# WASPADA environment template — copy to .env and fill in. (.env is gitignored.)
# Every var the package reads is documented here; set only what a ticket needs.

# --- Decision lane (which lifecycle decision to run) ---
# collections (default, the hero/EWS lane) | origination
WASPADA_LANE=collections

# --- Alibaba Cloud OSS — three-bucket medallion (WA-057) ---
# Three physically isolated buckets: Raw (immutable source) → Staging (curated
# lane views) → Mart (serving layer). Agents read from Raw, write to Staging
# and Mart. No compute role ever writes to Raw.
OSS_RAW_BUCKET=waspada-prod-raw
OSS_STAGING_BUCKET=waspada-prod-staging
OSS_MART_BUCKET=waspada-prod-mart
# OSS endpoint (S3-compatible). Singapore = oss-ap-southeast-1.aliyuncs.com
OSS_ENDPOINT=
# Object key for the loan-portfolio Parquet (in the Raw bucket).
OSS_KEY=loans.parquet
# AccessKey pair (RAM user) — from the Alibaba Cloud console (NEVER commit).
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# --- Dataset acquisition ---
# Owner-provided LendingClub file path or URL (no Kaggle login anywhere).
LC_SOURCE_PATH=

# --- Agent framework (WA-008) ---
# Which reasoning brain the agent framework uses. mock (default, offline,
# deterministic) | qwen (opt-in; needs openai + DASHSCOPE_API_KEY — the Agent Society
# risk-auditor negotiation brain, via Alibaba Cloud Model Studio/DashScope).
WASPADA_LLM_PROVIDER=mock
# Qwen Cloud (only when WASPADA_LLM_PROVIDER=qwen). Get a key at
# https://home.qwencloud.com (docs: https://docs.qwencloud.com) — backed by
# Alibaba Cloud DashScope, same OpenAI-compatible endpoint either way.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL is the DEFAULT model for the base brain. The pipeline overrides it
# per agent by cognitive-load tier — override each tier here to point at models
# your DashScope account actually serves (leave blank to use the defaults):
#   flash → Data Engineer + Risk Auditor (Skeptic)   default qwen3.6-flash
#   plus  → Data Analyst + Actuary rebuttal           default qwen3.7-plus
#   max   → Arbiter rulings                           default qwen3.7-max
QWEN_MODEL=qwen3.7-plus
QWEN_MODEL_FLASH=
QWEN_MODEL_PLUS=
QWEN_MODEL_MAX=
# Human-in-loop gate: 1 = auto-approve (non-prod / smoke runs; logged with
# auto=True so an audit can tell it from a real human sign-off). Leave unset
# for production — the gate then blocks until a human decides.
WASPADA_AUTO_APPROVE=

# --- Auth (WA-028 / WA-040) ---
# Environment toggle. 'dev' (or unset) = local/demo: an insecure JWT fallback
# is tolerated. Any other value (e.g. 'prod') = the app REFUSES to start unless
# WASPADA_JWT_SECRET is set and ≥ 32 bytes. Set this to 'prod' for the FC deploy.
WASPADA_ENV=dev
# JWT signing secret. MUST be ≥ 32 bytes in non-dev environments (the app
# refuses to start otherwise). Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# In dev (WASPADA_ENV unset/'dev') leaving this blank falls back to an insecure
# default — logged loudly on startup. NEVER commit a real secret.
WASPADA_JWT_SECRET=
# User store. ApsaraDB RDS PostgreSQL connection string in prod (the 5th
# Alibaba Cloud service) — e.g.
#   postgres://USER:PASS@rm-xxx.pg.rds.aliyuncs.com:5432/waspada
# Unset (or sqlite:///./waspada.db) → stdlib SQLite local-dev fallback, which
# is what the test suite and the local demo use.
DATABASE_URL=
# Demo analyst password (logged on first start). Change for any real demo.
WASPADA_DEMO_PASSWORD=waspada123
