# WASPADA environment template. Copy to `.env` and fill in. `.env` is gitignored.
# All vars are optional for local dev / tests (see waspada/config.py).

# --- BigQuery (the data warehouse; filled in by WA-002) ---
BQ_PROJECT=
BQ_DATASET=
BQ_TABLE=

# --- Lane switch: "collections" (default) | "origination" ---
WASPADA_LANE=collections

# --- WSL->GPU bridge overrides (optional; used by waspada/wsl.py) ---
# WSL executable (default: "wsl"). Set to an absolute path if not on PATH.
# WASPADA_WSL_BIN=wsl
# GPU-side RAPIDS python inside WSL (default: "/root/rapids/bin/python").
# WASPADA_GPU_PY=/root/rapids/bin/python
