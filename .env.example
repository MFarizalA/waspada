# WASPADA environment template — copy to .env and fill in. (.env is gitignored.)
# Every var the package reads is documented here; set only what a ticket needs.

# --- Decision lane (which lifecycle decision to run) ---
# collections (default, the hero/EWS lane) | origination
WASPADA_LANE=collections

# --- Alibaba Cloud OSS (data warehouse; the loan-portfolio Parquet object) ---
OSS_BUCKET=
OSS_ENDPOINT=
# Object key/path within the bucket, e.g. collections/loans.parquet
OSS_KEY=
# AccessKey pair (RAM user) — from the Alibaba Cloud console (NEVER commit).
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# --- Dataset acquisition ---
# Owner-provided LendingClub file path or URL (no Kaggle login anywhere).
LC_SOURCE_PATH=

# --- Agent framework (WA-008) ---
# Which reasoning brain the agent framework uses. mock (default, offline,
# deterministic) | gemini (opt-in; needs google-generativeai + GEMINI_API_KEY)
# | qwen (opt-in; needs openai + DASHSCOPE_API_KEY — the Agent Society
# risk-auditor negotiation brain, via Alibaba Cloud Model Studio/DashScope).
WASPADA_LLM_PROVIDER=mock
# Gemini free-tier key (only when WASPADA_LLM_PROVIDER=gemini).
GEMINI_API_KEY=
# Qwen Cloud (only when WASPADA_LLM_PROVIDER=qwen). Get a key at
# https://home.qwencloud.com (docs: https://docs.qwencloud.com) — backed by
# Alibaba Cloud DashScope, same OpenAI-compatible endpoint either way.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus
# Human-in-loop gate: 1 = auto-approve (non-prod / smoke runs; logged with
# auto=True so an audit can tell it from a real human sign-off). Leave unset
# for production — the gate then blocks until a human decides.
WASPADA_AUTO_APPROVE=
