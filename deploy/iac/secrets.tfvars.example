# Copy this file to secrets.tfvars and fill in your values.
#   cp secrets.tfvars.example secrets.tfvars
# secrets.tfvars is gitignored — never commit real credentials.
#
# Alternatively, export TF_VAR_* env vars in your shell
# and run tofu apply with no -var-file.

access_key         = "YOUR_ALIYUN_ACCESS_KEY_ID"
secret_key         = "YOUR_ALIYUN_ACCESS_KEY_SECRET"
rds_password       = "YOUR_RDS_MASTER_PASSWORD"
dashscope_api_key  = "YOUR_DASHSCOPE_API_KEY"
waspada_jwt_secret = "YOUR_32_PLUS_BYTE_JWT_SECRET"
