# Copy this file to secrets.tfvars and fill in your AccessKey.
#   cp secrets.tfvars.example secrets.tfvars
# secrets.tfvars is gitignored — never commit real credentials.
#
# Alternatively, export TF_VAR_access_key / TF_VAR_secret_key in your shell
# and run tofu apply with no -var-file.

access_key = "YOUR_ALIYUN_ACCESS_KEY_ID"
secret_key = "YOUR_ALIYUN_ACCESS_KEY_SECRET"
